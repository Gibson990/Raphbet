# Copy to .env and fill in. The server reads these on startup.
# Without API_SPORTS_KEY the server serves built-in mock World Cup data.

# HTTP port the API listens on.
PORT=8080

# Comma-separated front-end origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:3000

# api-football (api-sports.io) credentials.
# Get a free key (100 requests/day) at https://www.api-football.com/
API_SPORTS_KEY=
API_SPORTS_BASE_URL=https://v3.football.api-sports.io

# Competition season. FIFA World Cup 2026 => 2026.
SEASON=2026

# House margin / overround applied to generated odds (0.07 = 7% edge).
HOUSE_MARGIN=0.07

# Cache TTLs (Go duration syntax). Tuned for the 100 req/day free tier.
FIXTURES_TTL=1h
LIVE_TTL=30s
STANDINGS_TTL=6h

# Wallet & bets
INITIAL_BALANCE=1000000      # virtual credits seeded into a new wallet (TZS)
SETTLEMENT_INTERVAL=30s      # how often pending bets are settled from results

# Persistence: set MONGO_URI to use MongoDB; leave empty for in-memory.
# Local (Docker):  mongodb://localhost:27017
# Atlas (cloud):   mongodb+srv://USER:PASS@cluster.xxxx.mongodb.net
MONGO_URI=
MONGO_DB=raphbet

# Admin dashboard passcode (sandbox auth; replaced by a Firebase admin role later)
ADMIN_KEY=raphbet-admin
